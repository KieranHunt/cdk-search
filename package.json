{
  "name": "cdk-search",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun ./index.html",
    "prebuild": "bun run download-jsii && bun run build:index && bun run check && bun run lint && bun run test",
    "build": "bun run build.ts",
    "download-jsii": "bun run scripts/download-jsii.ts",
    "build:index": "bun run scripts/build-index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "lint": "oxlint src/ scripts/ build.ts vitest.config.ts && oxfmt --check src/ scripts/ build.ts vitest.config.ts",
    "lint:fix": "oxlint --fix src/ scripts/ build.ts vitest.config.ts && oxfmt src/ scripts/ build.ts vitest.config.ts",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-navigation-menu": "^1",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-plugin-tailwind": "latest",
    "ky": "^1.14.3",
    "lefthook": "^2.1.3",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.51.0",
    "remove-markdown": "^0.6.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
