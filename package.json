{
	"name": "cdk-search",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "bun ./index.html",
		"prebuild": "tsc --noEmit && biome check src/ build.ts",
		"build": "bun run build.ts",
		"check": "tsc --noEmit",
		"lint": "biome check src/ build.ts",
		"lint:fix": "biome check --write src/ build.ts",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@radix-ui/react-dialog": "^1",
		"@radix-ui/react-navigation-menu": "^1",
		"react": "^19",
		"react-dom": "^19",
		"tailwindcss": "^4.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "^1.3.10",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"bun-plugin-tailwind": "latest",
		"lefthook": "^2.1.3",
		"typescript": "^5.9.3"
	}
}
